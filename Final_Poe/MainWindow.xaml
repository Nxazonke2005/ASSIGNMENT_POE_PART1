<Window x:Class="CyberSecurityAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot - Part 3"
        Height="800"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#25253A"
                CornerRadius="15"
                BorderBrush="#3A3A55"
                BorderThickness="2"
                Padding="10"
                Margin="0,0,0,10">

            <StackPanel>
                <TextBlock Text="CYBERSECURITY AWARENESS BOT - PART 3"
                           Foreground="#45D6FF"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Task Assistant | Mini Game Quiz | NLP | Activity Log"
                           Foreground="#8888AA"
                           FontSize="14"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Feature Buttons -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="#25253A"
                CornerRadius="15"
                BorderBrush="#3A3A55"
                BorderThickness="2"
                Padding="10"
                Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Name="btnNewChat" Content="New Chat" Click="btnNewChat_Click"
                        Background="#2D4F6C" Foreground="White" FontWeight="Bold"
                        Padding="15,8" Margin="5" BorderThickness="0" Cursor="Hand"/>

                <Button Name="btnTasks" Content="Tasks" Click="btnTasks_Click"
                        Background="#2D4F6C" Foreground="White" FontWeight="Bold"
                        Padding="15,8" Margin="5" BorderThickness="0" Cursor="Hand"/>

                <Button Name="btnQuiz" Content="Quiz" Click="btnQuiz_Click"
                        Background="#2D4F6C" Foreground="White" FontWeight="Bold"
                        Padding="15,8" Margin="5" BorderThickness="0" Cursor="Hand"/>

                <Button Name="btnActivity" Content="Activity Log" Click="btnActivity_Click"
                        Background="#2D4F6C" Foreground="White" FontWeight="Bold"
                        Padding="15,8" Margin="5" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <Border Grid.Row="2" Grid.Column="0"
                Background="#25253A"
                CornerRadius="15"
                BorderBrush="#3A3A55"
                BorderThickness="2"
                Padding="10"
                Margin="0,0,10,10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="ChatStackPanel"/>
                </ScrollViewer>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Name="txtMessage"
                             Height="40"
                             FontSize="14"
                             Background="#1E1E2F"
                             Foreground="White"
                             BorderBrush="#45D6FF"
                             BorderThickness="2"
                             VerticalContentAlignment="Center"
                             Padding="10"
                             KeyDown="txtMessage_KeyDown"/>

                    <Button Name="btnSend"
                            Grid.Column="1"
                            Content="Send"
                            Margin="10,0,0,0"
                            Height="40"
                            Width="80"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#00E676"
                            Foreground="White"
                            BorderThickness="0"
                            Click="btnSend_Click"
                            Cursor="Hand"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Side Panel -->
        <Border Grid.Row="2" Grid.Column="1"
                Background="#25253A"
                CornerRadius="15"
                BorderBrush="#3A3A55"
                BorderThickness="2"
                Padding="10"
                Margin="0,0,0,10">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Name="SidePanelStackPanel">

                    <!-- Tasks Section -->
                    <TextBlock Text="MY TASKS" Foreground="#45D6FF" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <ListBox Name="lstTasks" Height="150" Background="#1E1E2F" Foreground="White" BorderBrush="#3A3A55">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Reminder}" Foreground="#FFA500" FontSize="11"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Button Content="Complete" Tag="{Binding}" Click="btnCompleteTask_Click"
                                                Background="#4CAF50" Foreground="White" FontSize="10" Padding="5,2" Margin="0,0,5,0"/>
                                        <Button Content="Delete" Tag="{Binding}" Click="btnDeleteTask_Click"
                                                Background="#F44336" Foreground="White" FontSize="10" Padding="5,2"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Separator Margin="0,15,0,15" Background="#3A3A55"/>

                    <!-- Quiz Section -->
                    <TextBlock Text="QUIZ RESULTS" Foreground="#45D6FF" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <Border Background="#1E1E2F" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Name="txtQuizScore" Text="Score: 0/0" Foreground="White" FontSize="14"/>
                            <TextBlock Name="txtQuizFeedback" Text="Start a quiz to test your knowledge!" Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap"/>
                            <Button Name="btnStartQuiz" Content="Start Quiz" Click="btnStartQuiz_Click"
                                    Background="#FF6B35" Foreground="White" FontWeight="Bold" Padding="10,5" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,15,0,15" Background="#3A3A55"/>

                    <!-- Activity Log Section -->
                    <TextBlock Text="RECENT ACTIVITIES" Foreground="#45D6FF" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <ListBox Name="lstActivity" Height="120" Background="#1E1E2F" Foreground="White" BorderBrush="#3A3A55"
                             FontSize="11">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="5,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Name="btnRefreshLog" Content="Refresh Log" Click="btnRefreshLog_Click"
                            Background="#2D4F6C" Foreground="White" FontSize="11" Padding="10,3" Margin="0,5,0,0"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Grid.ColumnSpan="2"
                Background="#25253A"
                CornerRadius="10"
                BorderBrush="#3A3A55"
                BorderThickness="1"
                Padding="10"
                Margin="0,10,0,0">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="#00E676" Margin="10,0,10,0"/>
                <TextBlock Text="System Ready | Part 3 | SQLite | Task Assistant | Quiz | Activity Log | NLP Enabled"
                           Foreground="White" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>